{
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "System":    "Warning"
      }
    },
    "Enrich": ["FromLogContext", "WithMachineName", "WithProcessId", "WithThreadId", "WithCorrelationId"],
    "Properties": {
      "Application": "OrderService"
    }
  },
  "Seq": {
    "ServerUrl": "http://seq:5341"
  },
  "Jaeger": {
    "OtlpEndpoint": "http://jaeger:4317"
  },
  "AllowedHosts": "*"
}

