{
  "Serilog": {
    "Using": ["Serilog.Sinks.Console", "Serilog.Sinks.Seq"],
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft":                "Warning",
        "Microsoft.AspNetCore":    "Warning",
        "System":                  "Warning",
        "Microsoft.EntityFrameworkCore": "Warning"
      }
    },
    "Enrich": [
      "FromLogContext",
      "WithMachineName",
      "WithProcessId",
      "WithThreadId",
      "WithCorrelationId"
    ],
    "Properties": {
      "Application": "ApiService",
      "Environment": "Docker"
    }
  },
  "Seq": {
    "ServerUrl": "http://seq:5341"
  },
  "Jaeger": {
    "OtlpEndpoint": "http://jaeger:4317"
  },
  "ConnectionStrings": {
    "SqlServer": "Server=sqlserver;Database=ObservabilityDb;User Id=sa;Password=YourStrong!Passw0rd;TrustServerCertificate=True"
  },
  "Redis": {
    "ConnectionString": "redis:6379"
  },
  "Services": {
    "OrderService":     "http://order-service:8081",
    "InventoryService": "http://inventory-service:8082"
  },
  "ExternalApis": {
    "PaymentGateway": "https://httpstat.us/200"
  },
  "AllowedHosts": "*"
}

